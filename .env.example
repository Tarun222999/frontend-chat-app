# Server-side Upstash Redis session store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Structured JSON logging threshold.
LOG_LEVEL=info

# Neon Postgres database for durable AI chat storage.
NEON_DATABASE_URL=

# Personal chat backend mode.
PERSONAL_CHAT_SERVICE_MODE=gateway

# Gateway HTTP API URL, reachable from the deployed Next.js server.
PERSONAL_CHAT_GATEWAY_URL=https://your-gateway.example.com

# Gateway Socket.IO URL, reachable from end-user browsers.
PERSONAL_CHAT_GATEWAY_SOCKET_URL=https://your-gateway-socket.example.com

# Optional gateway/session tuning.
PERSONAL_CHAT_GATEWAY_FETCH_TIMEOUT_MS=5000
PERSONAL_CHAT_SESSION_TTL_SECONDS=604800
PERSONAL_CHAT_REALTIME_BRIDGE_TTL_SECONDS=1800

# Public app origin used by server-side Eden client calls.
NEXT_PUBLIC_APP_URL=https://your-frontend.example.com

# Local transport generation only; not required at runtime.
OPENAPI_SPEC=../fullstack_microservice/docs/openapi.yaml

# AI chat backend mode. Use mock for local UI/dev without provider calls.
AI_CHAT_SERVICE_MODE=mock

# AI chat limits and default model profile.
AI_CHAT_DEFAULT_PROFILE=free
AI_CHAT_MAX_INPUT_CHARS=12000
AI_CHAT_MAX_HISTORY_MESSAGES=30
AI_CHAT_RATE_LIMIT_PER_MINUTE=10

# Provider API keys. Only configured providers are required in provider mode.
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# User-facing profile mapping.
AI_CHAT_FREE_PROVIDER=google
AI_CHAT_FREE_MODEL=gemini-2.5-flash-lite

AI_CHAT_FAST_PROVIDER=groq
AI_CHAT_FAST_MODEL=llama-3.1-8b-instant

AI_CHAT_BALANCED_PROVIDER=google
AI_CHAT_BALANCED_MODEL=gemini-2.5-flash
