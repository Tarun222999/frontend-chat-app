# Server-side Upstash Redis session store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Personal chat backend mode.
PERSONAL_CHAT_SERVICE_MODE=gateway

# Gateway HTTP API URL, reachable from the deployed Next.js server.
PERSONAL_CHAT_GATEWAY_URL=https://your-gateway.example.com

# Gateway Socket.IO URL, reachable from end-user browsers.
PERSONAL_CHAT_GATEWAY_SOCKET_URL=https://your-gateway-socket.example.com

# Optional gateway/session tuning.
PERSONAL_CHAT_GATEWAY_FETCH_TIMEOUT_MS=5000
PERSONAL_CHAT_SESSION_TTL_SECONDS=604800
PERSONAL_CHAT_REALTIME_BRIDGE_TTL_SECONDS=1800

# Public app origin used by server-side Eden client calls.
NEXT_PUBLIC_APP_URL=https://your-frontend.example.com

# Local transport generation only; not required at runtime.
OPENAPI_SPEC=../fullstack_microservice/docs/openapi.yaml
