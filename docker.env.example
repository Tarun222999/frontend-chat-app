# Used by docker compose through environment interpolation.
# Put real values in your local .env or shell environment.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# mock uses the in-memory personal chat service.
# gateway forwards personal chat calls to PERSONAL_CHAT_GATEWAY_URL.
PERSONAL_CHAT_SERVICE_MODE=mock
DOCKER_PERSONAL_CHAT_GATEWAY_URL=http://host.docker.internal:4000
DOCKER_PERSONAL_CHAT_SOCKET_URL=http://host.docker.internal:4002
PERSONAL_CHAT_GATEWAY_FETCH_TIMEOUT_MS=5000
PERSONAL_CHAT_SESSION_TTL_SECONDS=604800
PERSONAL_CHAT_REALTIME_BRIDGE_TTL_SECONDS=1800

# Required for private chat routes and Upstash Realtime.
# Also required when PERSONAL_CHAT_SERVICE_MODE=gateway.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
